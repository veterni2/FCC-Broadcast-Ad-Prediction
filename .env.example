# FCC Political Ad Revenue Estimator — environment configuration
# Copy to .env and fill in values. Never commit .env to git.

# ---------------------------------------------------------------------------
# Anthropic Claude (required for Stage 4 LLM extraction)
# ---------------------------------------------------------------------------
# Either FCC_LLM_API_KEY or ANTHROPIC_API_KEY is accepted.
ANTHROPIC_API_KEY=sk-ant-api03-...

# Claude model (default shown — change only if a newer Sonnet is preferred)
FCC_LLM_MODEL=claude-sonnet-4-20250514

# Max tokens per extraction call (4096 is sufficient for single-page invoices)
FCC_LLM_MAX_TOKENS=4096

# Per-run API cost budget in USD (stops extraction if exceeded; partial results kept)
FCC_LLM_COST_BUDGET_PER_RUN=5.00

# ---------------------------------------------------------------------------
# FCC OPIF site settings
# ---------------------------------------------------------------------------
FCC_BASE_URL=https://publicfiles.fcc.gov

# Requests per second to the FCC site — do NOT raise above 2.0 without
# monitoring for HTTP 429 responses. The site has informal rate limiting.
FCC_RATE_LIMIT_RPS=1.5

# Max concurrent HTTP connections (for PDF downloads, not Playwright)
FCC_MAX_CONCURRENT=3

# ---------------------------------------------------------------------------
# PDF processing
# ---------------------------------------------------------------------------
# OCR engine: 'paddleocr' (preferred, better accuracy) or 'tesseract' (fallback)
# PaddleOCR requires: pip install -e ".[ocr,dev]" and Visual C++ Build Tools on Windows
# Tesseract requires the Tesseract binary on PATH
FCC_PDF_OCR_ENGINE=paddleocr

# Minimum characters per page before OCR is triggered
FCC_PDF_MIN_TEXT_CHARS_PER_PAGE=50

# PDF storage directory (relative to project root)
FCC_PDF_STORAGE_DIR=./data/pdfs

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
FCC_DB_PATH=./data/documents.db

# ---------------------------------------------------------------------------
# Output
# ---------------------------------------------------------------------------
FCC_OUTPUT_DIR=./output
